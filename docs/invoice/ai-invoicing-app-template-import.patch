+import type { FastifyPluginAsync } from 'fastify';
+import { z } from 'zod';
+
+import {
+  INVOICE_TEMPLATE_FORMAT,
+  parseInvoiceTemplate,
+} from '../domain/invoice-templates/schema.js';
+
+const importSchema = z.object({
+  template: z.unknown(),
+  activate: z.boolean().default(true),
+});
+
+/**
+ * Import / activate ALEYA invoice template packages.
+ * Storage: preferences category `invoice` → `{ activeTemplate, importedAt, format }`.
+ */
+export const invoiceTemplateRoutes: FastifyPluginAsync = async (app) => {
+  app.post('/integrations/invoice-templates/import', async (request, reply) => {
+    const body = importSchema.parse(request.body);
+    const template = parseInvoiceTemplate(body.template);
+
+    const existing = ((await app.db.getPreference('invoice')) as Record<string, unknown> | null) ?? {};
+    const next = {
+      ...existing,
+      activeTemplate: template,
+      importedAt: new Date().toISOString(),
+      format: INVOICE_TEMPLATE_FORMAT,
+      version: template.version,
+      sourceMode: template.sourceMode ?? null,
+      activated: body.activate,
+    };
+    await app.db.upsertPreference('invoice', next);
+
+    // Also mirror brand colours onto business profile when present.
+    const profile = await app.db.getBusinessProfile();
+    if (profile) {
+      await app.db.upsertBusinessProfile({
+        companyName: profile.companyName,
+        legalName: profile.legalName ?? undefined,
+        abnTaxId: profile.abnTaxId ?? undefined,
+        address: profile.address ?? undefined,
+        email: profile.email ?? undefined,
+        phone: profile.phone ?? undefined,
+        logoReference: profile.logoReference ?? undefined,
+        primaryColor: template.theme.primaryColor || profile.primaryColor,
+        secondaryColor: template.theme.secondaryColor || profile.secondaryColor,
+      });
+    }
+
+    return reply.code(201).send({
+      message: 'Invoice template imported',
+      format: template.format,
+      version: template.version,
+      sourceMode: template.sourceMode,
+      regionCount: template.regions.length,
+      activated: body.activate,
+    });
+  });
+
+  app.get('/integrations/invoice-templates/active', async (_request, reply) => {
+    const prefs = (await app.db.getPreference('invoice')) as Record<string, unknown> | null;
+    const template = prefs?.activeTemplate;
+    if (!template) {
+      return reply.code(404).send({ message: 'No active invoice template' });
+    }
+    return {
+      format: INVOICE_TEMPLATE_FORMAT,
+      importedAt: prefs?.importedAt ?? null,
+      sourceMode: prefs?.sourceMode ?? null,
+      template,
+    };
+  });
+
+  app.delete('/integrations/invoice-templates/active', async (_request, reply) => {
+    const existing = ((await app.db.getPreference('invoice')) as Record<string, unknown> | null) ?? {};
+    const { activeTemplate: _drop, ...rest } = existing;
+    await app.db.upsertPreference('invoice', {
+      ...rest,
+      activeTemplate: null,
+      activated: false,
+      clearedAt: new Date().toISOString(),
+    });
+    return reply.code(200).send({ message: 'Active invoice template cleared' });
+  });
+};
