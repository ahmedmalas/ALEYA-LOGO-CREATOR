+        .fontSize(11)
+        .fillColor(text)
+        .text('Notes', 48, 650);
+      doc.font('Helvetica').fontSize(10).fillColor(muted).text(input.invoice.notes, 48, 666, {
+        width: 300,
+      });
+    }
+    if (input.invoice.paymentTerms) {
+      doc
+        .font('Helvetica-Bold')
+        .fontSize(11)
+        .fillColor(text)
+        .text('Payment', 48, 720);
+      doc
+        .font('Helvetica')
+        .fontSize(10)
+        .fillColor(muted)
+        .text(input.invoice.paymentTerms, 48, 736, { width: 500 });
+    }
+
+    doc
+      .fontSize(9)
+      .fillColor(muted)
+      .text(
+        `${profile?.companyName ?? 'Business'} · Template ${input.template.sourceMode ?? 'imported'} · Aleya Invoicing`,
+        48,
+        800,
+        { width: 500, align: 'center' },
+      );
+
+    doc.end();
+  });
+}
+
+/** Convenience: use template when provided, else caller uses legacy generator. */
+export function hasUsableInvoiceTemplate(value: unknown): value is InvoiceTemplate {
+  return Boolean(
