+import { z } from 'zod';
+
+export const INVOICE_TEMPLATE_FORMAT = 'aleya.invoiceTemplate' as const;
+export const INVOICE_TEMPLATE_VERSION = '1.0.0' as const;
+
+export const invoiceTemplateSchema = z.object({
+  format: z.literal(INVOICE_TEMPLATE_FORMAT),
+  version: z.string(),
+  page: z.object({
+    size: z.enum(['A4', 'Letter']).default('A4'),
+    orientation: z.enum(['portrait', 'landscape']).default('portrait'),
+    widthPt: z.number().default(595.28),
+    heightPt: z.number().default(841.89),
+    margins: z.object({
+      top: z.number(),
+      right: z.number(),
+      bottom: z.number(),
+      left: z.number(),
+    }),
+  }),
+  theme: z.object({
+    primaryColor: z.string(),
+    secondaryColor: z.string(),
+    textColor: z.string(),
+    mutedColor: z.string(),
+    borderColor: z.string(),
+    backgroundColor: z.string(),
+    fontFamily: z.string(),
+    headingFontFamily: z.string(),
+  }),
+  regions: z.array(
+    z.object({
+      id: z.string(),
+      type: z.string(),
+      label: z.string().default(''),
+      bounds: z.object({
+        x: z.number(),
+        y: z.number(),
+        width: z.number(),
+        height: z.number(),
+      }),
+      style: z
+        .object({
+          fontFamily: z.string().optional(),
+          fontSize: z.number().optional(),
+          fontWeight: z.enum(['normal', 'bold']).optional(),
+          color: z.string().optional(),
+          align: z.enum(['left', 'center', 'right']).optional(),
+          background: z.string().optional(),
+          borderColor: z.string().optional(),
+          borderWidth: z.number().optional(),
+        })
+        .default({}),
+      binding: z.string().default(''),
+      editable: z.boolean().default(true),
+    }),
+  ),
+  table: z.object({
+    regionId: z.string().default('line-items'),
+    columns: z.array(
+      z.object({
+        id: z.string(),
+        header: z.string(),
+        binding: z.string(),
+        width: z.number(),
+        align: z.enum(['left', 'center', 'right']).default('left'),
+      }),
+    ),
+    headerBackground: z.string().default('#F3F4F6'),
+    rowBorderColor: z.string().default('#E5E7EB'),
+  }),
+  variables: z.array(z.string()).default([]),
+  sampleData: z.record(z.string(), z.unknown()).optional(),
+  sourceMode: z.enum(['mirror', 'refine', 'advance']).optional(),
+  analysis: z.record(z.string(), z.unknown()).optional(),
+  assets: z
+    .object({
+      logo: z.string().optional(),
+    })
+    .default({}),
+});
+
+export type InvoiceTemplate = z.infer<typeof invoiceTemplateSchema>;
+
+export function parseInvoiceTemplate(raw: unknown): InvoiceTemplate {
+  return invoiceTemplateSchema.parse(raw);
+}
