+import PDFDocument from 'pdfkit';
+
+import type { InvoiceTemplate } from '../domain/invoice-templates/schema.js';
+import type { BrandingProfile, Customer, InvoiceDraft, LineItemInput } from '../types/entities.js';
+import { drawBusinessLogoMark } from './logo-pdf.js';
+
+function money(n: number): string {
+  return n.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
+}
+
+/**
+ * Render an invoice PDF using an imported ALEYA template layout.
+ * Falls back gracefully when regions are missing.
+ */
+export function generateTemplatedInvoicePdfBuffer(input: {
+  template: InvoiceTemplate;
+  invoice: InvoiceDraft;
+  lineItems: LineItemInput[];
+  customer: Customer;
+  businessProfile: BrandingProfile | null;
+}): Promise<Buffer> {
+  return new Promise((resolve, reject) => {
+    const pageSize = input.template.page.size === 'Letter' ? 'LETTER' : 'A4';
+    const doc = new PDFDocument({
+      size: pageSize,
+      margins: {
+        top: input.template.page.margins.top,
+        bottom: input.template.page.margins.bottom,
+        left: input.template.page.margins.left,
+        right: input.template.page.margins.right,
+      },
+    });
+    const chunks: Buffer[] = [];
+    doc.on('data', (chunk: Buffer) => chunks.push(chunk));
+    doc.on('end', () => resolve(Buffer.concat(chunks)));
+    doc.on('error', (err) => reject(err));
+
+    const theme = input.template.theme;
+    const profile = input.businessProfile;
+    const primary = profile?.primaryColor || theme.primaryColor || '#1F4D45';
+    const text = theme.textColor || '#111827';
+    const muted = theme.mutedColor || '#6B7280';
+
+    // Logo
+    drawBusinessLogoMark(doc, profile, 420, 48, 48);
+
+    // Company
+    doc
+      .fillColor(primary)
+      .font('Helvetica-Bold')
+      .fontSize(20)
+      .text(profile?.companyName || 'Business Name', 48, 48, { width: 320 });
+    doc
+      .font('Helvetica')
+      .fontSize(10)
+      .fillColor(muted)
+      .text(
+        [profile?.address, profile?.email, profile?.phone, profile?.abnTaxId ? `ABN ${profile.abnTaxId}` : null]
+          .filter(Boolean)
+          .join('\n'),
+        48,
+        doc.y + 4,
+        { width: 320 },
+      );
+
+    // Title + meta (right)
+    doc
+      .fillColor(text)
+      .font('Helvetica-Bold')
+      .fontSize(18)
+      .text('TAX INVOICE', 360, 100, { width: 180, align: 'right' });
+    doc
+      .font('Helvetica')
+      .fontSize(10)
+      .text(
+        [
+          `Invoice: ${input.invoice.invoiceNumber ?? 'Draft'}`,
+          `Issue: ${input.invoice.issueDate}`,
+          `Due: ${input.invoice.dueDate}`,
+        ].join('\n'),
+        360,
+        126,
+        { width: 180, align: 'right' },
+      );
+
+    // Customer
+    doc
+      .fillColor(text)
+      .font('Helvetica-Bold')
+      .fontSize(11)
+      .text('Bill To', 48, 200);
+    doc
+      .font('Helvetica')
+      .fontSize(10)
+      .fillColor(text)
+      .text(
+        [input.customer.displayName, input.customer.address, input.customer.email]
+          .filter(Boolean)
+          .join('\n'),
+        48,
+        216,
+        { width: 260 },
+      );
+
+    // Table
+    const tableTop = 300;
+    const columns = input.template.table.columns;
+    let x = 48;
+    doc.rect(48, tableTop, 500, 22).fill(input.template.table.headerBackground || '#F3F4F6');
+    doc.fillColor(muted).fontSize(9).font('Helvetica-Bold');
+    for (const col of columns) {
+      doc.text(col.header, x, tableTop + 6, {
+        width: col.width,
+        align: col.align === 'right' ? 'right' : 'left',
+      });
+      x += col.width;
+    }
+
+    let y = tableTop + 28;
+    doc.font('Helvetica').fontSize(10).fillColor(text);
+    for (const item of input.lineItems) {
+      const lineSubtotal = item.quantity * item.unitPrice;
+      const lineGst = item.gstApplicable ? lineSubtotal * 0.1 : 0;
+      const lineTotal = lineSubtotal + lineGst;
+      const values: Record<string, string> = {
+        description: item.description,
+        quantity: String(item.quantity),
+        unitPrice: money(item.unitPrice),
+        tax: money(lineGst),
+        total: money(lineTotal),
+      };
+      x = 48;
+      for (const col of columns) {
+        doc.text(values[col.binding] ?? values[col.id] ?? '', x, y, {
+          width: col.width,
+          align: col.align === 'right' ? 'right' : 'left',
+        });
+        x += col.width;
+      }
+      doc
+        .strokeColor(input.template.table.rowBorderColor || '#E5E7EB')
+        .moveTo(48, y + 16)
+        .lineTo(548, y + 16)
+        .stroke();
+      y += 22;
+      if (y > 700) break;
+    }
+
+    // Totals
+    const totals = input.invoice.totals;
+    doc
+      .font('Helvetica')
+      .fontSize(11)
+      .fillColor(text)
+      .text(`Subtotal: ${money(totals.subtotal)}`, 360, Math.max(y + 20, 560), {
+        width: 180,
+        align: 'right',
+      });
+    doc.text(`GST: ${money(totals.gstTotal)}`, 360, doc.y + 2, { width: 180, align: 'right' });
+    doc
+      .font('Helvetica-Bold')
+      .fillColor(primary)
+      .fontSize(13)
+      .text(`Total: ${money(totals.total)}`, 360, doc.y + 4, { width: 180, align: 'right' });
+
+    // Notes / payment
+    if (input.invoice.notes) {
+      doc
+        .font('Helvetica-Bold')
+        .fontSize(11)
+        .fillColor(text)
+        .text('Notes', 48, 650);
+      doc.font('Helvetica').fontSize(10).fillColor(muted).text(input.invoice.notes, 48, 666, {
+        width: 300,
+      });
+    }
+    if (input.invoice.paymentTerms) {
+      doc
+        .font('Helvetica-Bold')
+        .fontSize(11)
+        .fillColor(text)
+        .text('Payment', 48, 720);
+      doc
+        .font('Helvetica')
+        .fontSize(10)
+        .fillColor(muted)
+        .text(input.invoice.paymentTerms, 48, 736, { width: 500 });
+    }
+
+    doc
+      .fontSize(9)
+      .fillColor(muted)
+      .text(
+        `${profile?.companyName ?? 'Business'} · Template ${input.template.sourceMode ?? 'imported'} · Aleya Invoicing`,
+        48,
+        800,
+        { width: 500, align: 'center' },
+      );
+
+    doc.end();
+  });
+}
+
+/** Convenience: use template when provided, else caller uses legacy generator. */
+export function hasUsableInvoiceTemplate(value: unknown): value is InvoiceTemplate {
+  return Boolean(
+    value &&
+      typeof value === 'object' &&
+      (value as { format?: string }).format === 'aleya.invoiceTemplate' &&
+      Array.isArray((value as { regions?: unknown }).regions),
+  );
+}
