+/**
+ * Proof: import ALEYA template JSON → create invoice → generate PDF.
+ * Run from ai-invoicing-app-standalone: npx tsx scripts/proof-template-import.ts
+ */
+import { mkdir, readFile, writeFile } from 'node:fs/promises';
+import path from 'node:path';
+
+import { buildApp } from '../src/app.js';
+
+const OUT = '/opt/cursor/artifacts/invoice-pipeline/invoicing';
+
+async function main() {
+  await mkdir(OUT, { recursive: true });
+  const templatePath = process.argv[2] || '/opt/cursor/artifacts/invoice-pipeline/refine-template.json';
+  const template = JSON.parse(await readFile(templatePath, 'utf8'));
+
+  const app = await buildApp({
+    dbPath: path.join(OUT, 'proof.sqlite'),
+    authBypassForTesting: true,
+    enableStructuredLogging: false,
+    logLevel: 'error',
+  });
+  await app.ready();
+
+  await app.inject({
+    method: 'POST',
+    url: '/api/business-profile',
+    payload: {
+      companyName: 'Northwind Trading Co',
+      address: '12 Harbour Street, Sydney NSW 2000',
+      email: 'accounts@northwind.example',
+      phone: '+61 2 9000 1200',
+      abnTaxId: '12 345 678 901',
+      primaryColor: '#1F4D45',
+      secondaryColor: '#B08A4F',
+    },
+  });
+
+  const customerRes = await app.inject({
+    method: 'POST',
+    url: '/api/customers',
+    payload: {
+      displayName: 'Contoso Retail Pty Ltd',
+      email: 'ap@contoso.example',
+      address: '88 Market Road, Melbourne VIC 3000',
+    },
+  });
+  const customer = customerRes.json() as { id: string };
+
+  const importRes = await app.inject({
+    method: 'POST',
+    url: '/api/integrations/invoice-templates/import',
+    payload: { template, activate: true },
+  });
+  await writeFile(path.join(OUT, 'import-response.json'), importRes.body);
+  if (importRes.statusCode >= 300) {
+    throw new Error(`Import failed: ${importRes.statusCode} ${importRes.body}`);
+  }
+
+  const activeRes = await app.inject({ method: 'GET', url: '/api/integrations/invoice-templates/active' });
+  await writeFile(path.join(OUT, 'active-template.json'), activeRes.body);
+
+  const invoiceRes = await app.inject({
+    method: 'POST',
+    url: '/api/invoices',
+    payload: {
+      customerId: customer.id,
+      title: 'Shelving supply',
+      issueDate: '2026-07-01',
+      dueDate: '2026-07-31',
+      notes: 'Goods remain property of Northwind until paid in full.',
+      paymentTerms: 'Pay to Northwind Trading Co · BSB 062-000 Account 1234 5678',
+      lineItems: [
+        { description: 'Premium oak shelving unit', quantity: 4, unitPrice: 220, gstApplicable: true },
+        { description: 'Installation labour (half day)', quantity: 1, unitPrice: 480, gstApplicable: true },
+        { description: 'Protective packing materials', quantity: 2, unitPrice: 35, gstApplicable: true },
+      ],
+    },
+  });
+  const invoice = invoiceRes.json() as { id: string };
+  await app.inject({ method: 'POST', url: `/api/invoices/${invoice.id}/finalise` });
+
+  const pdfRes = await app.inject({ method: 'GET', url: `/api/invoices/${invoice.id}/pdf` });
+  if (pdfRes.statusCode !== 200 || !pdfRes.rawPayload.slice(0, 4).equals(Buffer.from('%PDF'))) {
+    throw new Error(`PDF failed: ${pdfRes.statusCode}`);
+  }
+  await writeFile(path.join(OUT, 'generated-invoice.pdf'), pdfRes.rawPayload);
+
+  // Dynamic swap proof — different customer/items
+  const customer2Res = await app.inject({
+    method: 'POST',
+    url: '/api/customers',
+    payload: {
+      displayName: 'Adventure Works Ltd',
+      email: 'billing@adventure.example',
+      address: '1 Innovation Way, Brisbane QLD 4000',
+    },
+  });
+  const customer2 = customer2Res.json() as { id: string };
+  const invoice2Res = await app.inject({
+    method: 'POST',
+    url: '/api/invoices',
+    payload: {
+      customerId: customer2.id,
+      title: 'Consulting',
+      issueDate: '2026-07-18',
+      dueDate: '2026-08-17',
+      notes: 'Net 30',
+      paymentTerms: 'Card or EFT',
+      lineItems: [
+        { description: 'Consulting day rate', quantity: 3, unitPrice: 900, gstApplicable: true },
+      ],
+    },
+  });
+  const invoice2 = invoice2Res.json() as { id: string };
+  await app.inject({ method: 'POST', url: `/api/invoices/${invoice2.id}/finalise` });
+  const pdf2 = await app.inject({ method: 'GET', url: `/api/invoices/${invoice2.id}/pdf` });
+  await writeFile(path.join(OUT, 'generated-invoice-swapped.pdf'), pdf2.rawPayload);
+
+  const summary = {
+    importStatus: importRes.statusCode,
+    activeStatus: activeRes.statusCode,
+    pdfBytes: pdfRes.rawPayload.length,
+    swappedPdfBytes: pdf2.rawPayload.length,
+    pdfPath: path.join(OUT, 'generated-invoice.pdf'),
+    swappedPdfPath: path.join(OUT, 'generated-invoice-swapped.pdf'),
+    ok: true,
+  };
+  await writeFile(path.join(OUT, 'summary.json'), JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify(summary, null, 2));
+  await app.close();
+}
+
+main().catch((err) => {
+  console.error(err);
+  process.exit(1);
+});
