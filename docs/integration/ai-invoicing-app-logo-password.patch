+import { describe, expect, it, vi, afterEach } from 'vitest';
+
+import { buildApp } from '../../src/app.js';
+
+describe('Logo Creator integration', () => {
+  afterEach(() => vi.unstubAllEnvs());
+
+  it('generates a signed launch URL and accepts a signed Brand Kit callback', async () => {
+    vi.stubEnv('LOGO_CREATOR_URL', 'https://aleya-logo-creator.example');
+    vi.stubEnv('INTEGRATION_HMAC_SECRET', 'test-shared-secret');
+
+    const app = await buildApp({
+      dbPath: ':memory:',
+      nodeEnv: 'test',
+      authBypassForTesting: true,
+    });
+    await app.db.upsertBusinessProfile({
+      companyName: 'Quantum Hire Services',
+      address: '1 Scaffold Way',
+      primaryColor: '#173f35',
+      secondaryColor: '#c4f36b',
+    });
+
+    const launch = await app.inject({
+      method: 'GET',
+      url: '/api/integrations/logo-creator/launch?return_url=https%3A%2F%2Finvoicing.example%2Fsettings',
+    });
+    expect(launch.statusCode).toBe(200);
+
+    const launchUrl = new URL(launch.json<{ launchUrl: string }>().launchUrl);
+    expect(launchUrl.origin).toBe('https://aleya-logo-creator.example');
+    expect(launchUrl.searchParams.get('business_id')).toBe('business-profile');
+    expect(launchUrl.searchParams.get('sig')).toMatch(/^[a-f0-9]{64}$/);
+
+    const receive = await app.inject({
+      method: 'POST',
+      url: '/api/integrations/logo-creator/receive',
+      payload: {
+        return_url: launchUrl.searchParams.get('return_url'),
+        business_id: launchUrl.searchParams.get('business_id'),
+        workspace_id: launchUrl.searchParams.get('workspace_id'),
+        state: launchUrl.searchParams.get('state'),
+        exp: launchUrl.searchParams.get('exp'),
+        sig: launchUrl.searchParams.get('sig'),
+        brand_kit_id: 'brand-kit-123',
+        logo_url: 'https://cdn.example/logo.png',
+        primary_color: '#101820',
+        secondary_color: '#FEE715',
+      },
+    });
+
+    expect(receive.statusCode).toBe(200);
+    const profile = await app.db.getBusinessProfile();
+    expect(profile?.brandKitId).toBe('brand-kit-123');
+    expect(profile?.logoReference).toBe('https://cdn.example/logo.png');
+    expect(profile?.logoAssetPath).toBe('https://cdn.example/logo.png');
+    expect(profile?.primaryColor).toBe('#101820');
+    expect(profile?.secondaryColor).toBe('#FEE715');
+
+    const rejected = await app.inject({
+      method: 'POST',
+      url: '/api/integrations/logo-creator/receive',
+      payload: {
+        return_url: launchUrl.searchParams.get('return_url'),
+        business_id: launchUrl.searchParams.get('business_id'),
+        workspace_id: launchUrl.searchParams.get('workspace_id'),
+        state: launchUrl.searchParams.get('state'),
+        exp: launchUrl.searchParams.get('exp'),
+        sig: '0'.repeat(64),
+        brand_kit_id: 'brand-kit-456',
+        logo_url: 'https://cdn.example/other.png',
+      },
+    });
+    expect(rejected.statusCode).toBe(401);
+
+    await app.close();
+  });
+
+  it('serves quote PDFs with business branding available', async () => {
+    const app = await buildApp({
+      dbPath: ':memory:',
+      nodeEnv: 'test',
+      authBypassForTesting: true,
+    });
+    await app.db.upsertBusinessProfile({
+      companyName: 'Quote Brand',
+      address: '7 Quote St',
+      logoReference: 'https://cdn.example/quote-logo.png',
+      primaryColor: '#173f35',
+      secondaryColor: '#c4f36b',
+    });
+    const customer = await app.db.createCustomer({ displayName: 'Quote Customer' });
+    const quote = await app.db.createQuote({
+      customerId: customer.id,
+      title: 'Logo-aware quote',
+      issueDate: '2026-07-18',
+      expiryDate: '2026-08-18',
+      lineItems: [{ description: 'Design', quantity: 1, unitPrice: 250, gstApplicable: true }],
+    });
+
+    const response = await app.inject({ method: 'GET', url: `/api/quotes/${quote.id}/pdf` });
+    expect(response.statusCode).toBe(200);
+    expect(response.headers['content-type']).toContain('application/pdf');
+    expect(response.body.slice(0, 5)).toBe('%PDF-');
+
+    await app.close();
+  });
+});
