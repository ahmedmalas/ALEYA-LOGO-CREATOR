+    if (/^https?:\/\//i.test(reference)) {
+      const response = await fetch(reference);
+      if (!response.ok) return null;
+      return Buffer.from(await response.arrayBuffer());
+    }
+    const dataUrl = reference.match(/^data:image\/(?:png|jpe?g);base64,(.+)$/i);
+    if (dataUrl?.[1]) return Buffer.from(dataUrl[1], 'base64');
+    const localPath = isAbsolute(reference) ? reference : resolve(process.cwd(), reference);
+    const workspaceRoot = resolve(process.cwd());
+    if (localPath !== workspaceRoot && !localPath.startsWith(`${workspaceRoot}/`)) return null;
+    return await readFile(localPath);
+  } catch {
+    return null;
+  }
+}
