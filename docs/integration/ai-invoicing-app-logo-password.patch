diff --git a/ai-invoicing-app-standalone/src/routes/logo-creator-integration.ts b/ai-invoicing-app-standalone/src/routes/logo-creator-integration.ts
new file mode 100644
index 0000000..c4e5638
--- /dev/null
+++ b/ai-invoicing-app-standalone/src/routes/logo-creator-integration.ts
@@ -0,0 +1,226 @@
+import { createHmac, randomUUID, timingSafeEqual } from 'node:crypto';
+
+import type { FastifyPluginAsync, FastifyReply, FastifyRequest } from 'fastify';
+import { z } from 'zod';
+
+import { runWithWorkspaceContext } from '../auth/workspace-context.js';
+
+const PUBLIC_WORKSPACE_ID = '00000000-0000-0000-0000-000000000001';
+const SIGNED_PAYLOAD_KEYS = ['business_id', 'exp', 'return_url', 'state', 'workspace_id'] as const;
+const hexColorSchema = z.string().regex(/^#[0-9A-Fa-f]{6}$/);
+
+const launchSchema = z.object({
+  return_url: z.string().url().optional(),
+});
+
+const receiveSchema = z
+  .object({
+    return_url: z.string().url(),
+    business_id: z.string().min(1),
+    workspace_id: z.string().min(1),
+    state: z.string().min(8),
+    exp: z.coerce.number().int(),
+    sig: z.string().regex(/^[a-f0-9]{64}$/i),
+    brand_kit_id: z.string().min(1).optional(),
+    brandKitId: z.string().min(1).optional(),
+    logo_url: z.string().min(1).optional(),
+    logoUrl: z.string().min(1).optional(),
+    logo_reference: z.string().min(1).optional(),
+    logoReference: z.string().min(1).optional(),
+    logo_asset_path: z.string().min(1).optional(),
+    logoAssetPath: z.string().min(1).optional(),
+    logo_data_url: z.string().min(1).optional(),
+    logoDataUrl: z.string().min(1).optional(),
+    logo_png_base64: z.string().min(1).optional(),
+    logoPngBase64: z.string().min(1).optional(),
+    primary_color: hexColorSchema.optional(),
+    primaryColor: hexColorSchema.optional(),
+    secondary_color: hexColorSchema.optional(),
+    secondaryColor: hexColorSchema.optional(),
+    palette: z.unknown().optional(),
+  })
+  .passthrough();
+
+type SignedPayload = Record<(typeof SIGNED_PAYLOAD_KEYS)[number], string>;
+
+function integrationSecret(): string | null {
+  const secret = process.env.INTEGRATION_HMAC_SECRET?.trim();
+  return secret ? secret : null;
+}
+
+function logoCreatorUrl(): string | null {
+  const url = process.env.LOGO_CREATOR_URL?.trim();
+  return url ? url : null;
+}
+
+function canonicalPayload(payload: SignedPayload): string {
+  return SIGNED_PAYLOAD_KEYS.map((key) => `${key}=${payload[key]}`).join('\n');
+}
+
+function signPayload(payload: SignedPayload, secret: string): string {
+  return createHmac('sha256', secret).update(canonicalPayload(payload)).digest('hex');
+}
+
+function verifySignature(payload: SignedPayload, signature: string, secret: string): boolean {
+  const expected = Buffer.from(signPayload(payload, secret), 'hex');
+  const received = Buffer.from(signature, 'hex');
+  return received.length === expected.length && timingSafeEqual(received, expected);
+}
+
+function firstString(...values: Array<unknown>): string | undefined {
+  for (const value of values) {
+    if (typeof value === 'string' && value.trim()) return value.trim();
+  }
+  return undefined;
+}
+
+function dataUrlFromBase64(value: string | undefined): string | undefined {
+  if (!value) return undefined;
+  return value.startsWith('data:image/') ? value : `data:image/png;base64,${value}`;
+}
+
+function paletteColor(palette: unknown, index: number): string | undefined {
+  if (Array.isArray(palette)) {
+    const value = (palette as unknown[])[index];
+    return typeof value === 'string' && hexColorSchema.safeParse(value).success ? value : undefined;
+  }
+  if (palette && typeof palette === 'object') {
+    const record = palette as Record<string, unknown>;
+    const keys = index === 0 ? ['primary', 'brand', 'accent'] : ['secondary', 'supporting'];
+    const value = firstString(...keys.map((key) => record[key]));
+    return value && hexColorSchema.safeParse(value).success ? value : undefined;
+  }
+  return undefined;
+}
+
+function isUsableLogoReference(value: string | undefined): value is string {
+  if (!value || value.startsWith('placeholder://')) return false;
+  if (/^https?:\/\//i.test(value)) return true;
+  if (/^data:image\/(?:png|jpe?g);base64,/i.test(value)) return true;
+  return value.startsWith('/') || value.startsWith('./') || value.startsWith('../');
+}
+
+export const logoCreatorIntegrationRoutes: FastifyPluginAsync = async (app) => {
+  async function buildLaunchResponse(
+    request: FastifyRequest,
+    reply: FastifyReply,
+    input: z.infer<typeof launchSchema>,
+  ) {
+    const secret = integrationSecret();
+    const baseUrl = logoCreatorUrl();
+    if (!secret || !baseUrl) {
+      return reply.code(503).send({ message: 'Logo Creator integration is not configured' });
+    }
+
+    const profile = await app.db.getBusinessProfile();
+    if (!profile) {
+      return reply.code(400).send({ message: 'Create business profile before launching Logo Creator' });
+    }
+
+    const launchUrl = new URL(baseUrl);
+    const signedPayload: SignedPayload = {
+      business_id: profile.id,
+      workspace_id: request.auth.workspaceId ?? PUBLIC_WORKSPACE_ID,
+      return_url: input.return_url ?? process.env.PUBLIC_APP_URL ?? 'http://localhost:3000/settings',
+      state: randomUUID(),
+      exp: String(Math.floor(Date.now() / 1000) + 10 * 60),
+    };
+    const sig = signPayload(signedPayload, secret);
+    for (const key of SIGNED_PAYLOAD_KEYS) launchUrl.searchParams.set(key, signedPayload[key]);
+    launchUrl.searchParams.set('sig', sig);
+
+    return {
+      launchUrl: launchUrl.toString(),
+      expiresAt: new Date(Number(signedPayload.exp) * 1000).toISOString(),
+    };
+  }
+
+  app.get('/integrations/logo-creator/launch', async (request, reply) => {
+    return await buildLaunchResponse(request, reply, launchSchema.parse(request.query));
+  });
+
+  app.post('/integrations/logo-creator/launch', async (request, reply) => {
+    return await buildLaunchResponse(request, reply, launchSchema.parse(request.body ?? {}));
+  });
+
+  app.post('/integrations/logo-creator/receive', async (request, reply) => {
+    const secret = integrationSecret();
+    if (!secret) {
+      return reply.code(503).send({ message: 'Logo Creator integration is not configured' });
+    }
+
+    const body = receiveSchema.parse(request.body);
+    const signedPayload: SignedPayload = {
+      business_id: body.business_id,
+      workspace_id: body.workspace_id,
+      return_url: body.return_url,
+      state: body.state,
+      exp: String(body.exp),
+    };
+    if (body.exp < Math.floor(Date.now() / 1000)) {
+      return reply.code(401).send({ message: 'Logo Creator handoff has expired' });
+    }
+    if (!verifySignature(signedPayload, body.sig, secret)) {
+      return reply.code(401).send({ message: 'Logo Creator handoff signature is invalid' });
+    }
+
+    const logoAssetPath = firstString(
+      body.logo_asset_path,
+      body.logoAssetPath,
+      body.logo_data_url,
+      body.logoDataUrl,
+      dataUrlFromBase64(firstString(body.logo_png_base64, body.logoPngBase64)),
+    );
+    const logoReference = firstString(
+      logoAssetPath,
+      body.logo_url,
+      body.logoUrl,
+      body.logo_reference,
+      body.logoReference,
+    );
+    if (!isUsableLogoReference(logoReference)) {
+      return reply.code(400).send({ message: 'Logo Creator payload did not include a usable logo URL or asset path' });
+    }
+
+    const workspace = await app.db.getWorkspaceById(body.workspace_id);
+    if (!workspace) {
+      return reply.code(404).send({ message: 'Workspace not found for Logo Creator handoff' });
+    }
+
+    const profile = await runWithWorkspaceContext(
+      {
+        authUserId: 'logo-creator-integration',
+        workspaceId: workspace.workspaceId,
+        schemaName: workspace.schemaName,
+      },
+      async () => {
+        const existing = await app.db.getBusinessProfile();
+        if (!existing || existing.id !== body.business_id) {
+          throw new Error('Business profile not found for Logo Creator handoff');
+        }
+        const primaryColor =
+          firstString(body.primary_color, body.primaryColor, paletteColor(body.palette, 0)) ??
+          existing.primaryColor;
+        const secondaryColor =
+          firstString(body.secondary_color, body.secondaryColor, paletteColor(body.palette, 1)) ??
+          existing.secondaryColor;
+
+        return await app.db.upsertBusinessProfile({
+          companyName: existing.companyName,
+          legalName: existing.legalName ?? undefined,
+          abnTaxId: existing.abnTaxId ?? undefined,
+          address: existing.address ?? undefined,
+          email: existing.email ?? undefined,
+          phone: existing.phone ?? undefined,
+          logoReference,
+          brandKitId: firstString(body.brand_kit_id, body.brandKitId) ?? existing.brandKitId ?? undefined,
+          logoAssetPath: logoAssetPath ?? logoReference,
+          primaryColor,
+          secondaryColor,
+        });
+      },
+    );
+
+    return { message: 'Logo Creator brand kit received', profile };
+  });
+};
