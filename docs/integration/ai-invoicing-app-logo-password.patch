+async function openLogoCreator() {
+  const popup = window.open('', '_blank', 'noopener,noreferrer');
+  const params = new URLSearchParams({ return_url: location.origin + '/settings' });
+  const response = await api('/api/integrations/logo-creator/launch?' + params.toString());
