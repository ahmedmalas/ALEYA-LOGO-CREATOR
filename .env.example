NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Image generation (server-only). Without these, IMAGE_PROVIDER defaults to svg composer.
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_PROVIDER=

# Shared with Aleya Invoicing for signed handoff
INTEGRATION_HMAC_SECRET=replace-with-long-random-secret
ALEYA_INVOICING_RECEIVE_URL=https://your-aleya-app.vercel.app/api/integrations/logo-creator/receive

GENERATION_RATE_LIMIT_PER_HOUR=20
