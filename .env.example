NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional — not used by v1 browser/API session paths; keep server-only if present
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Image generation (server-only). Default is the SVG composer (no paid AI required).
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_VISION_MODEL=gpt-4o-mini
IMAGE_PROVIDER=svg
EXPORT_RATE_LIMIT_PER_HOUR=40
EXPORT_PRO_RATE_LIMIT_PER_HOUR=200
REFERENCE_PRO_GENERATIONS_PER_HOUR=200
# Optional billing flags (keep unset until Stripe is wired)
# STRIPE_SECRET_KEY=
# BILLING_PROVIDER=

# Shared with Aleya Invoicing for signed handoff
INTEGRATION_HMAC_SECRET=replace-with-long-random-secret
ALEYA_INVOICING_RECEIVE_URL=https://your-aleya-app.vercel.app/api/integrations/logo-creator/receive
# Comma-separated extra origins allowed for post-delivery return URLs
ALEYA_RETURN_URL_ALLOWLIST=https://your-aleya-app.vercel.app

GENERATION_RATE_LIMIT_PER_HOUR=20

# Project reference uploads (Free defaults; override via env)
REFERENCE_MAX_FILES_PER_PROJECT=10
REFERENCE_MAX_FILE_BYTES=5242880
REFERENCE_MAX_TOTAL_BYTES_PER_USER=52428800
REFERENCE_PRO_MAX_FILES_PER_PROJECT=40
REFERENCE_PRO_MAX_FILE_BYTES=10485760
REFERENCE_PRO_MAX_TOTAL_BYTES_PER_USER=262144000
